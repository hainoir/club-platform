# Copy this file to .env.local for local development.
# Never commit .env.local.

# Public Supabase config
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional geofence config for duty sign-in (client side)
NEXT_PUBLIC_STUDIO_LAT=39.181074
NEXT_PUBLIC_STUDIO_LNG=117.121380
NEXT_PUBLIC_STUDIO_RADIUS_METERS=80
NEXT_PUBLIC_STUDIO_MAX_GEO_ACCURACY_METERS=100

# Optional e2e credentials (used by smoke tests)
E2E_MEMBER_EMAIL=
E2E_MEMBER_PASSWORD=
E2E_ADMIN_EMAIL=
E2E_ADMIN_PASSWORD=
E2E_KEY_RECEIVER_EMAIL=
E2E_KEY_RECEIVER_PASSWORD=
